{
  "name": "bookmark-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env WRANGLER_WRITE_LOGS=false wrangler dev",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build && cross-env WRANGLER_WRITE_LOGS=false wrangler deploy --dry-run --outdir dist/worker",
    "deploy": "tsc --noEmit && vite build && cross-env WRANGLER_WRITE_LOGS=false wrangler deploy",
    "test": "vitest run",
    "preview": "cross-env WRANGLER_WRITE_LOGS=false wrangler dev"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "hono": "^4.7.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250514.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "cross-env": "^10.1.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "wrangler": "^4.15.2"
  }
}
