{
  "name": "bookmark-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx src/server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "preview": "npm run build && npm run dev:server"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "hono": "^4.7.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
